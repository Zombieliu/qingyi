    "@upstash/redis": "^1.34.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "contracts": "file:../contracts",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
    "jotai": "^2.18.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "source-map": "0.7.6",
    "stripe": "^20.3.1",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "web-vitals": "^5.1.0",
