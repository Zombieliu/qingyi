{
  "name": "delta-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "22.x",
    "pnpm": "9.x"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter app dev",
    "build": "pnpm --filter app build",
    "start": "pnpm --filter app start",
    "lint": "pnpm --filter app lint",
    "dev:mp:weapp": "pnpm --filter mp dev:weapp",
    "dev:mp:alipay": "pnpm --filter mp dev:alipay",
    "dev:mp:tt": "pnpm --filter mp dev:tt",
    "build:mp:weapp": "pnpm --filter mp build:weapp",
    "build:mp:alipay": "pnpm --filter mp build:alipay",
    "build:mp:tt": "pnpm --filter mp build:tt",
    "test:visual": "playwright test --config playwright.config.ts",
    "test:visual:core": "PW_PROFILE=core playwright test --config playwright.config.ts",
    "test:visual:full": "PW_PROFILE=full playwright test --config playwright.config.ts",
    "test:visual:compat": "PW_PROFILE=compat playwright test --config playwright.config.ts",
    "test:visual:update": "PW_PROFILE=full playwright test --config playwright.config.ts --update-snapshots",
    "test:chain:e2e": "PLAYWRIGHT_BASE_URL=http://localhost:3000 PW_PROFILE=chain playwright test --config playwright.config.ts",
    "test:admin:e2e": "PW_PROFILE=admin playwright test --config playwright.config.ts",
    "test:admin:full": "PW_PROFILE=admin E2E_MANTOU_WITHDRAW=1 playwright test --config playwright.config.ts",
    "test:flow": "node scripts/flow-test.mjs",
    "chain:init-dapp": "node scripts/chain-init-dapp.mjs",
    "chain:init-ruleset": "node scripts/chain-init-ruleset.mjs",
    "db:push": "pnpm --filter app db:push",
    "db:seed": "pnpm --filter app db:seed",
    "db:deploy": "pnpm --filter app db:deploy",
    "db:maintain": "node scripts/admin-maintenance.mjs",
    "test:chain:script": "node scripts/chain-e2e.mjs",
    "vercel:env:clear": "node scripts/vercel-env-clear.mjs",
    "vercel:env:sync": "node scripts/vercel-env-sync.mjs",
    "sentry:rotate": "node scripts/sentry-token-rotate.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "packages/app/src/**/*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored --config packages/app/eslint.config.mjs",
      "prettier --write"
    ],
    "packages/app/src/**/*.{json,css}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.2",
      "axios": ">=1.13.5",
      "bn.js": ">=5.2.3",
      "minimatch@<3.1.3": "3.1.3",
      "minimatch@>=5.0.0 <5.1.7": "5.1.7",
      "minimatch@>=8.0.0 <8.0.5": "8.0.5",
      "minimatch@>=9.0.0 <9.0.6": "9.0.6",
      "http-cache-semantics": ">=4.1.1",
      "cross-spawn": ">=7.0.5",
      "lodash-es": ">=4.17.23",
      "glob@>=10.2.0 <10.5.0": "10.5.0",
      "valibot": ">=1.2.0",
      "swiper": ">=12.1.2"
    }
  }
}
